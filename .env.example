DATABASE_URL=postgresql://user:password@localhost:5432/knockouts

# NextAuth.js (Google OAuth)
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Anthropic API — leave empty to disable AI generation entirely
ANTHROPIC_API_KEY=

# Master kill-switch for Claude API generation. "1"/"true" = on, anything else = off. Default: off.
AI_PREDICTIONS_ENABLED=false

# Twitter (X) API — OAuth 1.0a user-context credentials. Required for the
# admin Twitter tab. All four must be set or the integration is disabled.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# HMAC salt for tipping-league invite links. Must be at least 16 chars and
# kept secret — the integrity check on /pickem/leagues/invite/<code>/<hash>
# fails closed if this is missing or weak. Generate with `openssl rand -hex 32`.
LEAGUE_INVITE_SALT=
